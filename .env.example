# --- Database (required) ---
DATABASE_URL=""

# --- Better Auth (required in production) ---
# Secret: min 32 chars (e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=""
# Same as your public site URL, e.g. https://your-app.vercel.app
BETTER_AUTH_URL=""
# Public URL for the browser (auth client). Must match production domain.
NEXT_PUBLIC_APP_URL=""

# Optional: comma-separated origins if you use multiple domains
# BETTER_AUTH_TRUSTED_ORIGINS="https://your-app.vercel.app"

# --- Email (Resend) — required if you use signup / password reset / verify email ---
RESEND_API_KEY=""
# Must be a sender Resend has verified, e.g. "Aevio <onboarding@yourdomain.com>"
EMAIL_FROM=""

# --- Google Cloud — required for meal/image analysis (Gemini + GCS) ---
# Vertex AI + GenAI use the project id; Storage uses default credentials (see note below).
GCP_PROJECT_ID=""
# Optional; default "us-central1" except for some preview models ("global")
GCP_LOCATION=""
# Optional; default in code is gemini-3.1-pro-preview
GEMINI_MODEL_ID=""
# GCS bucket for meal image uploads
GCS_BUCKET_NAME=""

# Local: set GOOGLE_APPLICATION_CREDENTIALS to an absolute path to your service-account JSON.
GOOGLE_APPLICATION_CREDENTIALS=""
# Vercel: paste the full service-account JSON into this env var instead of committing a file.
GOOGLE_SERVICE_ACCOUNT_JSON=""

# --- AI Coach (ADK service) ---
# Next.js API route /api/agent forwards to this backend service.
# Local default in code is http://127.0.0.1:8010 if this is not set.
ADK_API_URL=""
